{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "image": {
      "type": "object",
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        },
        "tag": {
          "type": "string"
        },
        "digest": {
          "type": "string",
          "pattern": "^$|^sha256:[a-f0-9]{64}$"
        }
      },
      "additionalProperties": false
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": {
          "type": "boolean"
        },
        "annotations": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "name": {
          "type": "string"
        },
        "automount": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "config": {
      "type": "object",
      "properties": {
        "nats": {
          "type": "object",
          "properties": {
            "url": {
              "type": "string",
              "minLength": 1,
              "pattern": "^\\s*\\S+(\\s*,\\s*\\S+)*\\s*$",
              "description": "NATS server URL."
            },
            "stream": {
              "type": "string",
              "minLength": 1,
              "description": "JetStream stream name used for normalized events."
            },
            "subject_prefix": {
              "type": "string",
              "minLength": 1,
              "pattern": "^[^\\s*>]+(?:\\.[^\\s*>]+)*$",
              "description": "Subject prefix for published events."
            },
            "tenant_scoped_subjects": {
              "type": "boolean",
              "description": "Include tenant segment in NATS subjects."
            },
            "max_age": {
              "type": "string",
              "description": "JetStream message retention duration (for example 168h)."
            },
            "dedup_window": {
              "type": "string",
              "description": "JetStream deduplication window (for example 2m)."
            },
            "connect_timeout": {
              "type": "string",
              "description": "NATS connection timeout."
            },
            "reconnect_wait": {
              "type": "string",
              "description": "Delay between NATS reconnect attempts."
            },
            "max_reconnects": {
              "type": "integer",
              "minimum": -1,
              "description": "Maximum NATS reconnect attempts (-1 for unlimited)."
            },
            "publish_timeout": {
              "type": "string",
              "description": "Timeout for one NATS publish attempt."
            },
            "publish_max_retries": {
              "type": "integer",
              "minimum": 0,
              "maximum": 1000,
              "description": "Maximum publish retries after the initial NATS publish attempt."
            },
            "publish_retry_backoff": {
              "type": "string",
              "description": "Base exponential backoff for NATS publish retries."
            },
            "username": {
              "type": "string",
              "description": "Optional NATS username."
            },
            "password": {
              "type": "string",
              "description": "Optional NATS password."
            },
            "token": {
              "type": "string",
              "description": "Optional NATS token auth."
            },
            "creds_file": {
              "type": "string",
              "description": "Optional NATS creds file path."
            },
            "secure": {
              "type": "boolean",
              "description": "Use TLS for NATS client connections."
            },
            "insecure_skip_verify": {
              "type": "boolean",
              "description": "Skip NATS TLS certificate verification (use only for trusted internal endpoints)."
            },
            "ca_file": {
              "type": "string",
              "description": "Optional path to a PEM CA bundle used to validate NATS server certificates."
            },
            "cert_file": {
              "type": "string",
              "description": "Optional path to a PEM client certificate for mTLS to NATS."
            },
            "key_file": {
              "type": "string",
              "description": "Optional path to a PEM private key for mTLS to NATS."
            },
            "stream_replicas": {
              "type": "integer",
              "minimum": 1,
              "description": "JetStream stream replication factor."
            },
            "stream_storage": {
              "type": "string",
              "enum": ["file", "memory"],
              "description": "JetStream storage type."
            },
            "stream_discard": {
              "type": "string",
              "enum": ["old", "new"],
              "description": "JetStream discard policy when limits are reached."
            },
            "stream_max_consumers": {
              "type": "integer",
              "minimum": 0,
              "description": "Maximum number of JetStream consumers allowed on this stream (0 uses server default)."
            },
            "stream_max_msgs_per_subject": {
              "type": "integer",
              "minimum": 0,
              "description": "Maximum retained messages per subject in the JetStream stream (0 means unlimited)."
            },
            "stream_compression": {
              "type": "string",
              "enum": ["none", "s2"],
              "description": "JetStream stream file store compression mode."
            },
            "stream_allow_msg_ttl": {
              "type": "boolean",
              "description": "Allow per-message TTL using Nats-Msg-TTL header on the stream."
            },
            "stream_max_msgs": {
              "type": "integer",
              "minimum": 0,
              "description": "Maximum retained messages in JetStream stream (0 means unlimited)."
            },
            "stream_max_bytes": {
              "type": "integer",
              "minimum": 0,
              "description": "Maximum retained bytes in JetStream stream (0 means unlimited)."
            },
            "stream_max_msg_size": {
              "type": "integer",
              "minimum": 0,
              "maximum": 2147483647,
              "description": "Maximum message size accepted by JetStream stream in bytes (0 means unlimited)."
            }
          },
          "allOf": [
            {
              "if": {
                "required": ["password"],
                "properties": {
                  "password": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              },
              "then": {
                "required": ["username"],
                "properties": {
                  "username": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            },
            {
              "if": {
                "required": ["token"],
                "properties": {
                  "token": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              },
              "then": {
                "properties": {
                  "username": {
                    "maxLength": 0
                  },
                  "password": {
                    "maxLength": 0
                  }
                }
              }
            },
            {
              "if": {
                "required": ["creds_file"],
                "properties": {
                  "creds_file": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              },
              "then": {
                "properties": {
                  "username": {
                    "maxLength": 0
                  },
                  "password": {
                    "maxLength": 0
                  },
                  "token": {
                    "maxLength": 0
                  }
                }
              }
            },
            {
              "if": {
                "required": ["insecure_skip_verify"],
                "properties": {
                  "insecure_skip_verify": {
                    "const": true
                  }
                }
              },
              "then": {
                "properties": {
                  "secure": {
                    "const": true
                  }
                }
              }
            },
            {
              "if": {
                "required": ["ca_file"],
                "properties": {
                  "ca_file": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              },
              "then": {
                "properties": {
                  "secure": {
                    "const": true
                  }
                }
              }
            },
            {
              "if": {
                "required": ["cert_file"],
                "properties": {
                  "cert_file": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              },
              "then": {
                "required": ["key_file"],
                "properties": {
                  "key_file": {
                    "type": "string",
                    "minLength": 1
                  },
                  "secure": {
                    "const": true
                  }
                }
              }
            },
            {
              "if": {
                "required": ["key_file"],
                "properties": {
                  "key_file": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              },
              "then": {
                "required": ["cert_file"],
                "properties": {
                  "cert_file": {
                    "type": "string",
                    "minLength": 1
                  },
                  "secure": {
                    "const": true
                  }
                }
              }
            }
          ],
          "additionalProperties": false
        },
        "clickhouse": {
          "type": "object",
          "properties": {
            "addr": {
              "type": "string",
              "pattern": "^\\s*$|^\\s*[^,\\s]+:[0-9]{1,5}(\\s*,\\s*[^,\\s]+:[0-9]{1,5})*\\s*$",
              "description": "ClickHouse host:port (or comma-separated host:port list). Empty disables sink."
            },
            "database": {
              "type": "string",
              "minLength": 1,
              "description": "ClickHouse target database."
            },
            "table": {
              "type": "string",
              "minLength": 1,
              "description": "ClickHouse target table."
            },
            "username": {
              "type": "string",
              "minLength": 1,
              "description": "ClickHouse username."
            },
            "password": {
              "type": "string",
              "description": "ClickHouse password."
            },
            "secure": {
              "type": "boolean",
              "description": "Use TLS for ClickHouse client connections."
            },
            "insecure_skip_verify": {
              "type": "boolean",
              "description": "Skip ClickHouse TLS certificate verification (use only for trusted internal endpoints)."
            },
            "tls_server_name": {
              "type": "string",
              "description": "Optional TLS SNI/server name override for ClickHouse certificate validation."
            },
            "ca_file": {
              "type": "string",
              "description": "Optional path to a PEM CA bundle used to validate ClickHouse server certificates."
            },
            "cert_file": {
              "type": "string",
              "description": "Optional path to a PEM client certificate for mTLS to ClickHouse."
            },
            "key_file": {
              "type": "string",
              "description": "Optional path to a PEM private key for mTLS to ClickHouse."
            },
            "dial_timeout": {
              "type": "string",
              "description": "ClickHouse dial timeout."
            },
            "max_open_conns": {
              "type": "integer",
              "minimum": 1,
              "description": "Maximum ClickHouse open connections."
            },
            "max_idle_conns": {
              "type": "integer",
              "minimum": 0,
              "description": "Maximum idle ClickHouse connections."
            },
            "conn_max_lifetime": {
              "type": "string",
              "description": "Maximum ClickHouse connection lifetime."
            },
            "batch_size": {
              "type": "integer",
              "minimum": 1,
              "description": "Rows per ClickHouse insert batch."
            },
            "flush_interval": {
              "type": "string",
              "description": "Maximum interval before flushing pending ClickHouse rows."
            },
            "consumer_name": {
              "type": "string",
              "minLength": 1,
              "description": "NATS durable consumer name used by ClickHouse sink."
            },
            "consumer_fetch_batch_size": {
              "type": "integer",
              "minimum": 1,
              "description": "NATS pull-consumer fetch batch size for ClickHouse sink."
            },
            "consumer_fetch_max_wait": {
              "type": "string",
              "description": "NATS pull-consumer max wait per fetch."
            },
            "consumer_ack_wait": {
              "type": "string",
              "description": "NATS ack wait duration for ClickHouse sink consumer."
            },
            "consumer_max_ack_pending": {
              "type": "integer",
              "minimum": 1,
              "description": "Maximum pending acks for ClickHouse sink consumer."
            },
            "consumer_max_deliver": {
              "type": "integer",
              "minimum": -1,
              "description": "Maximum delivery attempts for ClickHouse sink consumer messages (-1 means unlimited, 0 uses server default)."
            },
            "consumer_backoff": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Optional explicit redelivery backoff schedule for ClickHouse sink consumer."
            },
            "consumer_max_waiting": {
              "type": "integer",
              "minimum": 0,
              "description": "Maximum waiting pull requests allowed on the ClickHouse sink consumer (0 uses server default)."
            },
            "consumer_max_request_max_bytes": {
              "type": "integer",
              "minimum": 0,
              "description": "Maximum bytes returned by one pull request for ClickHouse sink consumer (0 uses server default)."
            },
            "insert_timeout": {
              "type": "string",
              "description": "Timeout for a single ClickHouse insert flush."
            },
            "retention_ttl": {
              "type": "string",
              "description": "Retention TTL for ClickHouse table rows based on event time."
            }
          },
          "allOf": [
            {
              "if": {
                "properties": {
                  "insecure_skip_verify": {
                    "const": true
                  }
                }
              },
              "then": {
                "properties": {
                  "secure": {
                    "const": true
                  }
                }
              }
            },
            {
              "if": {
                "required": ["tls_server_name"],
                "properties": {
                  "tls_server_name": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              },
              "then": {
                "properties": {
                  "secure": {
                    "const": true
                  }
                }
              }
            },
            {
              "if": {
                "required": ["ca_file"],
                "properties": {
                  "ca_file": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              },
              "then": {
                "properties": {
                  "secure": {
                    "const": true
                  }
                }
              }
            },
            {
              "if": {
                "required": ["cert_file"],
                "properties": {
                  "cert_file": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              },
              "then": {
                "required": ["key_file"],
                "properties": {
                  "key_file": {
                    "type": "string",
                    "minLength": 1
                  },
                  "secure": {
                    "const": true
                  }
                }
              }
            },
            {
              "if": {
                "required": ["key_file"],
                "properties": {
                  "key_file": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              },
              "then": {
                "required": ["cert_file"],
                "properties": {
                  "cert_file": {
                    "type": "string",
                    "minLength": 1
                  },
                  "secure": {
                    "const": true
                  }
                }
              }
            }
          ],
          "additionalProperties": false
        },
        "vault": {
          "type": "object",
          "properties": {
            "address": {
              "type": "string",
              "description": "Vault API address. Required when any config field uses vault:// references unless provided via VAULT_ADDR."
            },
            "namespace": {
              "type": "string",
              "description": "Optional Vault Enterprise namespace header."
            },
            "auth_method": {
              "type": "string",
              "enum": ["kubernetes", "token"],
              "description": "Vault auth method used to resolve vault:// references."
            },
            "token": {
              "type": "string",
              "description": "Vault token used when auth_method=token (falls back to VAULT_TOKEN when empty)."
            },
            "token_file": {
              "type": "string",
              "description": "Path to a file containing Vault token when auth_method=token."
            },
            "kubernetes_role": {
              "type": "string",
              "description": "Vault role used when auth_method=kubernetes."
            },
            "kubernetes_mount_path": {
              "type": "string",
              "description": "Vault Kubernetes auth mount path."
            },
            "kubernetes_jwt_file": {
              "type": "string",
              "description": "Path to Kubernetes service account JWT used for Vault login."
            }
          },
          "additionalProperties": false
        },
        "server": {
          "type": "object",
          "properties": {
            "port": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535,
              "description": "HTTP listen port."
            },
            "base_path": {
              "type": "string",
              "minLength": 1,
              "description": "Webhook ingress base path."
            },
            "read_timeout": {
              "type": "string",
              "description": "HTTP server read timeout."
            },
            "write_timeout": {
              "type": "string",
              "description": "HTTP server write timeout."
            },
            "max_body_size": {
              "type": "integer",
              "minimum": 1,
              "description": "Maximum accepted request body size in bytes."
            },
            "admin_token": {
              "type": "string",
              "description": "Primary admin token for /admin endpoints."
            },
            "admin_token_secondary": {
              "type": "string",
              "description": "Optional secondary admin token used during rotation."
            },
            "admin_token_read": {
              "type": "string",
              "description": "Optional read-scope token for admin list/status endpoints."
            },
            "admin_token_replay": {
              "type": "string",
              "description": "Optional replay-scope token for POST /admin/replay-dlq."
            },
            "admin_token_cancel": {
              "type": "string",
              "description": "Optional cancel-scope token for DELETE /admin/replay-dlq/{job_id}."
            },
            "admin_replay_max_limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100000,
              "description": "Maximum records replayed by POST /admin/replay-dlq."
            },
            "admin_replay_job_ttl": {
              "type": "string",
              "description": "Retention window for in-memory admin replay job metadata (for example 24h)."
            },
            "admin_replay_job_max_jobs": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100000,
              "description": "Maximum number of replay jobs tracked in-memory."
            },
            "admin_replay_job_timeout": {
              "type": "string",
              "description": "Maximum execution time for one replay job attempt (for example 5m)."
            },
            "admin_replay_max_concurrent_jobs": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "description": "Maximum replay jobs executing concurrently."
            },
            "admin_replay_store_backend": {
              "type": "string",
              "enum": ["memory", "sqlite"],
              "description": "Replay job metadata backend."
            },
            "admin_replay_sqlite_path": {
              "type": "string",
              "description": "SQLite database path used when replay store backend is sqlite."
            },
            "admin_replay_require_reason": {
              "type": "boolean",
              "description": "Require X-Admin-Reason header on replay/cancel requests."
            },
            "admin_replay_reason_min_length": {
              "type": "integer",
              "minimum": 1,
              "description": "Minimum X-Admin-Reason length when provided (and when required)."
            },
            "admin_replay_max_queued_per_ip": {
              "type": "integer",
              "minimum": 0,
              "maximum": 100000,
              "description": "Maximum queued replay jobs allowed per requester IP."
            },
            "admin_replay_max_queued_per_token": {
              "type": "integer",
              "minimum": 0,
              "maximum": 100000,
              "description": "Maximum queued replay jobs allowed per admin token fingerprint."
            },
            "admin_rate_limit_per_sec": {
              "type": "number",
              "exclusiveMinimum": 0,
              "description": "Admin endpoint token-bucket refill rate (requests per second)."
            },
            "admin_rate_limit_burst": {
              "type": "integer",
              "minimum": 1,
              "description": "Admin endpoint token-bucket burst size."
            },
            "admin_allowed_cidrs": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Optional CIDR allowlist enforced on /admin endpoints."
            },
            "admin_mtls_required": {
              "type": "boolean",
              "description": "Require mTLS client certificate (or trusted forwarded cert header) on /admin endpoints."
            },
            "admin_mtls_client_cert_header": {
              "type": "string",
              "minLength": 1,
              "description": "Header used for forwarded client certificate identity when behind trusted TLS termination."
            }
          },
          "allOf": [
            {
              "if": {
                "properties": {
                  "admin_token_secondary": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              },
              "then": {
                "properties": {
                  "admin_token": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            },
            {
              "if": {
                "properties": {
                  "admin_replay_store_backend": {
                    "const": "sqlite"
                  }
                }
              },
              "then": {
                "properties": {
                  "admin_replay_sqlite_path": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            }
          ],
          "additionalProperties": false
        },
        "state": {
          "type": "object",
          "properties": {
            "backend": {
              "type": "string",
              "enum": ["memory", "sqlite"],
              "description": "Poller state backend."
            },
            "sqlite_path": {
              "type": "string",
              "description": "SQLite file path used when state.backend=sqlite."
            }
          },
          "additionalProperties": false
        }
      }
    },
    "autoscaling": {
      "type": "object",
      "properties": {
        "targetCPUUtilizationPercentage": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "targetMemoryUtilizationPercentage": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "customMetrics": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      }
    },
    "envSecrets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "secretName", "secretKey"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "secretName": { "type": "string", "minLength": 1 },
          "secretKey": { "type": "string", "minLength": 1 }
        }
      }
    },
    "extraVolumeMounts": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "extraVolumes": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "podDisruptionBudget": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "minAvailable": { "type": ["integer", "string", "null"] },
        "maxUnavailable": { "type": ["integer", "string", "null"] }
      }
    },
    "networkPolicy": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "allowConfigPorts": {
          "type": "boolean",
          "description": "Auto-allow TCP egress ports derived from config.nats.url and config.clickhouse.addr."
        },
        "extraEgressPorts": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1,
            "maximum": 65535
          },
          "description": "Additional cluster-wide TCP egress ports to allow."
        },
        "natsEgressTo": {
          "type": "array",
          "description": "Optional destination selectors for auto-derived NATS egress ports.",
          "items": {
            "type": "object",
            "properties": {
              "namespaceSelector": { "type": "object" },
              "podSelector": { "type": "object" },
              "ipBlock": { "type": "object" }
            },
            "additionalProperties": false
          }
        },
        "clickhouseEgressTo": {
          "type": "array",
          "description": "Optional destination selectors for auto-derived ClickHouse egress ports.",
          "items": {
            "type": "object",
            "properties": {
              "namespaceSelector": { "type": "object" },
              "podSelector": { "type": "object" },
              "ipBlock": { "type": "object" }
            },
            "additionalProperties": false
          }
        },
        "ingress": {
          "type": "array",
          "items": { "type": "object" }
        },
        "egress": {
          "type": "array",
          "items": { "type": "object" }
        }
      },
      "additionalProperties": false
    }
  }
}
