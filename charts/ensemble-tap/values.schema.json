{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "config": {
      "type": "object",
      "properties": {
        "server": {
          "type": "object",
          "properties": {
            "admin_token": {
              "type": "string",
              "description": "Primary admin token for /admin endpoints."
            },
            "admin_token_secondary": {
              "type": "string",
              "description": "Optional secondary admin token used during rotation."
            },
            "admin_replay_max_limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100000,
              "description": "Maximum records replayed by POST /admin/replay-dlq."
            },
            "admin_replay_job_ttl": {
              "type": "string",
              "description": "Retention window for in-memory admin replay job metadata (for example 24h)."
            },
            "admin_replay_job_max_jobs": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100000,
              "description": "Maximum number of replay jobs tracked in-memory."
            },
            "admin_rate_limit_per_sec": {
              "type": "number",
              "exclusiveMinimum": 0,
              "description": "Admin endpoint token-bucket refill rate (requests per second)."
            },
            "admin_rate_limit_burst": {
              "type": "integer",
              "minimum": 1,
              "description": "Admin endpoint token-bucket burst size."
            },
            "admin_allowed_cidrs": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Optional CIDR allowlist enforced on /admin endpoints."
            },
            "admin_mtls_required": {
              "type": "boolean",
              "description": "Require mTLS client certificate (or trusted forwarded cert header) on /admin endpoints."
            },
            "admin_mtls_client_cert_header": {
              "type": "string",
              "minLength": 1,
              "description": "Header used for forwarded client certificate identity when behind trusted TLS termination."
            }
          },
          "allOf": [
            {
              "if": {
                "properties": {
                  "admin_token_secondary": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              },
              "then": {
                "properties": {
                  "admin_token": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            }
          ]
        }
      }
    },
    "autoscaling": {
      "type": "object",
      "properties": {
        "targetCPUUtilizationPercentage": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "targetMemoryUtilizationPercentage": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "customMetrics": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      }
    },
    "envSecrets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "secretName", "secretKey"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "secretName": { "type": "string", "minLength": 1 },
          "secretKey": { "type": "string", "minLength": 1 }
        }
      }
    },
    "podDisruptionBudget": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "minAvailable": { "type": ["integer", "string", "null"] },
        "maxUnavailable": { "type": ["integer", "string", "null"] }
      }
    },
    "networkPolicy": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "ingress": {
          "type": "array",
          "items": { "type": "object" }
        },
        "egress": {
          "type": "array",
          "items": { "type": "object" }
        }
      }
    }
  }
}
